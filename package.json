{
  "name": "@acring/feishu-bitable-cli",
  "version": "1.0.3",
  "description": "飞书多维表格命令行工具，支持按 URL 查询记录与下载附件",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "bin": {
    "feishu-bitable": "./dist/bin/cli.js"
